<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.docvcs.gui.MainController">

    <top>
        <HBox spacing="10" padding="10">
            <Label text="DocVCS" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <TextField fx:id="usernameField" promptText="Username"/>
            <PasswordField fx:id="passwordField" promptText="Password"/>
            <Button text="Login" onAction="#handleLogin"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="10" padding="10">
            <Label text="Documents:" style="-fx-font-size: 16px;"/>
            <ListView fx:id="documentList"/>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="10" padding="10">
            <Button text="Upload File" onAction="#handleUpload"/>
            <Label fx:id="statusLabel" text=""/>
        </HBox>
    </bottom>

</BorderPane>